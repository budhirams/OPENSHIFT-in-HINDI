apiVersion: template.openshift.io/v1
kind:Template
metadata:
   name: octopus-template
   annotations:
     description: "This template deploys an Octopus Deploy server on Openshift."
   labels:
     app: octopus-app
     tier: frontend
     environment: production
objects:
  - apiVersion: v1
    kind: Depl
    metadata:
      name: octopus-app
      labels:
        app: octopus-app
    spec:
      replicas: 1
      selector:
         matchLabels:
            app: octopus-app
      template:
        metadata:
          labels:
            app: octopus-app
        spec:
          containers:
            - name: octopus-app
              image: bitnami/nginx
              ports:
                - containerPort: 8080
               resources:
                 limits:
                   memory: "512Mi"
                   cpu: "500m"
                 requests:
                   memory: "256Mi"
                   cpu: "250m"
- apiVersion: v1
    kind: Service
    metadata:
      name: octopus-service
    spec:
      selector:
        app: octopus-app
      ports:
          port: 80
          targetPort: 8080

oc autoscale deployment octopus-app --min=2 --max=8 --cpu-percent=75

